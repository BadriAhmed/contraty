{
  "id": "attestation-honneur-v1",
  "title_ar": "شهادة على الشرف",
  "title_fr": "Attestation sur l'Honneur",
  "slug": "attestation-honneur",
  "language": "both",
  "category": "demarches",
  "legal_basis": "Code des Obligations et des Contrats — Déclarations unilatérales",
  "version": "1.0",
  "reviewed_by": null,
